<!--
  Enables SPE remoting for local development and MCP server access.
  Grants the sitecore\IsAdministrator role access so admin/superuser can execute scripts remotely.
  DO NOT use in production.
-->
<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/" xmlns:role="http://www.sitecore.net/xmlconfig/role/">
  <sitecore role:require="Standalone or ContentManagement">
    <powershell>
      <services>
        <remoting>
          <patch:attribute name="enabled">true</patch:attribute>
          <authorization>
            <add Permission="Allow" IdentityType="Role" Identity="sitecore\IsAdministrator" />
          </authorization>
        </remoting>
      </services>
    </powershell>
  </sitecore>
</configuration>
